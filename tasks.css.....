/* ==========================
   DATA365 TASKS CSS
========================== */

:root{
    --primary:#6C3BFF;
    --primary-light:#8B5CFF;
    --bg:#F7F8FC;
    --card:#FFFFFF;
    --text:#1E1E1E;
    --sub:#757575;
    --shadow:0 8px 25px rgba(0,0,0,.08);
}

body.dark{
    --bg:#0F172A;
    --card:#1E293B;
    --text:#FFFFFF;
    --sub:#CBD5E1;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Poppins',sans-serif;
    background:var(--bg);
    color:var(--text);
    min-height:100vh;
    padding-bottom:100px;
}

a{
    text-decoration:none;
    color:inherit;
}

.app{
    padding:18px;
}

/* ==========================
   HEADER
========================== */

.page-header{
    margin-bottom:20px;
}

.page-header h2{
    font-size:24px;
    font-weight:700;
}

.page-header p{
    color:var(--sub);
    margin-top:4px;
}

/* ==========================
   STATS
========================== */

.task-stats{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:12px;
    margin-bottom:20px;
}

.stat-box{
    background:var(--card);
    border-radius:18px;
    padding:15px;
    text-align:center;
    box-shadow:var(--shadow);
}

.stat-box h3{
    color:var(--primary);
    font-size:22px;
}

.stat-box span{
    color:var(--sub);
    font-size:12px;
}

/* ==========================
   TASK CARD
========================== */

.task-card{
    background:var(--card);
    border-radius:22px;
    padding:18px;
    margin-bottom:18px;
    box-shadow:var(--shadow);
    animation:fadeUp .4s ease;
}

.task-top{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:12px;
}

.reward{
    background:#F1EBFF;
    color:var(--primary);
    padding:7px 12px;
    border-radius:30px;
    font-size:13px;
    font-weight:600;
}

.status{
    padding:7px 12px;
    border-radius:30px;
    font-size:12px;
    font-weight:600;
}

.available{
    background:#E7F9EC;
    color:#16A34A;
}

.pending{
    background:#FFF3D9;
    color:#F59E0B;
}

.completed{
    background:#DCFCE7;
    color:#16A34A;
}

.rejected{
    background:#FEE2E2;
    color:#DC2626;
}

.task-card h3{
    margin-bottom:8px;
}

.task-card p{
    color:var(--sub);
    line-height:1.6;
    margin-bottom:14px;
}

.task-info{
    font-size:13px;
    color:var(--sub);
    margin-bottom:15px;
}

/* ==========================
   BUTTONS
========================== */

.perform-btn,
.submit-proof,
.close-btn{
    width:100%;
    border:none;
    border-radius:14px;
    padding:14px;
    cursor:pointer;
    font-weight:600;
    transition:.3s;
}

.perform-btn{
    background:linear-gradient(
        135deg,
        var(--primary),
        var(--primary-light)
    );
    color:white;
}

.perform-btn:active{
    transform:scale(.97);
}

.submit-proof{
    margin-top:15px;
    background:var(--primary);
    color:white;
}

.close-btn{
    margin-top:10px;
    background:#E5E7EB;
    color:#111;
}

/* ==========================
   MODAL
========================== */

.modal{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.55);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:2000;
    padding:20px;
}

.modal-content{
    width:100%;
    max-width:420px;
    background:var(--card);
    border-radius:25px;
    padding:22px;
    animation:slideUp .3s ease;
}

.modal-content h3{
    margin-bottom:5px;
}

.modal-content p{
    color:var(--sub);
    margin-bottom:15px;
}

.modal-content label{
    display:block;
    margin-bottom:6px;
    font-size:14px;
    font-weight:500;
}

.modal-content input{
    width:100%;
    padding:13px;
    border:1px solid #DDD;
    border-radius:12px;
    margin-bottom:12px;
    background:transparent;
    color:var(--text);
}

/* ==========================
   LOADING SCREEN
========================== */

.loading-screen{
    position:fixed;
    inset:0;
    background:white;
    display:none;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    z-index:3000;
}

.loader{
    width:55px;
    height:55px;
    border:5px solid #E5E7EB;
    border-top:5px solid var(--primary);
    border-radius:50%;
    animation:spin 1s linear infinite;
    margin-bottom:20px;
}

.loading-screen h3{
    color:var(--primary);
    margin-bottom:8px;
}

.loading-screen p{
    color:var(--sub);
    text-align:center;
    max-width:260px;
}

/* ==========================
   BOTTOM NAV
========================== */

.bottom-nav{
    position:fixed;
    left:12px;
    right:12px;
    bottom:15px;

    display:flex;
    justify-content:space-around;
    align-items:center;

    background:rgba(255,255,255,.95);
    backdrop-filter:blur(20px);

    padding:12px;
    border-radius:24px;

    box-shadow:
    0 10px 35px rgba(0,0,0,.12);

    z-index:1000;
}

.bottom-nav a{
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:4px;
    color:var(--sub);
    transition:.3s;
}

.bottom-nav a.active{
    color:var(--primary);
}

.bottom-nav svg{
    width:22px;
    height:22px;
}

.bottom-nav span{
    font-size:11px;
}

/* ==========================
   ANIMATIONS
========================== */

@keyframes spin{

    from{
        transform:rotate(0deg);
    }

    to{
        transform:rotate(360deg);
    }

}

@keyframes slideUp{

    from{
        opacity:0;
        transform:translateY(25px);
    }

    to{
        opacity:1;
        transform:translateY(0);
    }

}

@keyframes fadeUp{

    from{
        opacity:0;
        transform:translateY(20px);
    }

    to{
        opacity:1;
        transform:translateY(0);
    }

}

/* ==========================
   RESPONSIVE
========================== */

@media(min-width:768px){

    .app{
        max-width:500px;
        margin:auto;
    }

    .bottom-nav{
        max-width:500px;
        margin:auto;
    }

}