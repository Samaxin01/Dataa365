<!-- PROOF MODAL -->

<div class="modal" id="proofModal">

    <div class="modal-content">

        <h3>
            Submit Task Proof
        </h3>

        <p>
            Upload screenshot proof
        </p>

        <form
            id="proofForm"
            action="https://formsubmit.co/mymargonapp@gmail.com"
            method="POST"
            enctype="multipart/form-data">

            <input
type="hidden"
name="userEmail"
id="hiddenEmail">

<input
type="hidden"
name="taskTitle"
id="hiddenTask">

         

            <input
                type="hidden"
                name="_subject"
                value="New Task Submission">

            <label>Email</label>

            <input
                type="email"
                id="userEmail"
                name="email"
                readonly>

            <label>Task</label>

            <input
                type="text"
                id="taskTitle"
                name="task"
                readonly>
            <input
type="hidden"
name="userEmail"
id="hiddenEmail">

<input
type="hidden"
name="taskTitle"
id="hiddenTask">

        <label>Screenshot</label>

<input
type="file"
name="attachment"
accept="image/*"
required>

            <button
                type="submit"
                class="submit-proof">

                Submit Proof

            </button>

        </form>

        <button
            id="closeModal"
            class="close-btn">

            Close

        </button>

    </div>

</div>

<!-- LOADING SCREEN -->

